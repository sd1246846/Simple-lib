--[[
COMPACT SNOW V5.6 - EXTERNAL EDITION
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

local Library = { Toggles = {}, Connections = {}, Sliders = {} }

local IsMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
local MainSize = IsMobile and UDim2.new(0, 360, 0, 240) or UDim2.new(0, 500, 0, 350)
local SidebarWidth = IsMobile and 90 or 120
local TextScale = IsMobile and 10 or 11

function Library:CreateWindow(title, restoreText)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "CompactV5_Final_Fix"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.DisplayOrder = 103838233
    ScreenGui.Parent = PlayerGui

    local function makeDraggable(topBar, frame)
        local dragging, dragStart, startPos
        topBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = frame.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
        end)
    end

    local MainFrame = Instance.new("Frame")
    MainFrame.Size = MainSize
    MainFrame.Position = UDim2.new(0.5, -MainSize.X.Offset/2, 0.5, -MainSize.Y.Offset/2)
    MainFrame.BackgroundColor3 = Color3.fromRGB(8, 8, 12)
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = ScreenGui
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)
    
    local function CreateSnow(parent, count)
        local container = Instance.new("Frame", parent)
        container.Size = UDim2.new(1, 0, 1, 0); container.BackgroundTransparency = 1; container.ZIndex = 0
        for i = 1, count do
            task.spawn(function()
                local flake = Instance.new("Frame", container)
                flake.Size = UDim2.new(0, 2, 0, 2); flake.BackgroundColor3 = Color3.fromRGB(255, 255, 255); flake.BackgroundTransparency = 0.5; flake.BorderSizePixel = 0
                Instance.new("UICorner", flake).CornerRadius = UDim.new(1, 0)
                flake.Position = UDim2.new(math.random(), 0, math.random(), 0)
                local speed = math.random(15, 35) / 100
                RunService.RenderStepped:Connect(function(dt)
                    if not ScreenGui.Parent then return end
                    flake.Position = flake.Position + UDim2.new(math.sin(tick() + i)*0.0004, 0, speed * dt, 0)
                    if flake.Position.Y.Scale > 1 then flake.Position = UDim2.new(math.random(), 0, -0.05, 0) end
                end)
            end)
        end
    end

    CreateSnow(MainFrame, IsMobile and 20 or 40)

    local TitleBar = Instance.new("Frame", MainFrame)
    TitleBar.Size = UDim2.new(1, 0, 0, 32); TitleBar.BackgroundColor3 = Color3.fromRGB(255, 255, 255); TitleBar.BackgroundTransparency = 0.97
    
    local TitleText = Instance.new("TextLabel", TitleBar)
    TitleText.Text = "  " .. (title or "COMPACT V5")
    TitleText.Size = UDim2.new(1, -65, 1, 0); TitleText.TextColor3 = Color3.fromRGB(255, 255, 255); TitleText.BackgroundTransparency = 1; TitleText.Font = "GothamBold"; TitleText.TextSize = TextScale; TitleText.TextXAlignment = "Left"

    local Controls = Instance.new("Frame", TitleBar)
    Controls.Size = UDim2.new(0, 60, 1, 0); Controls.Position = UDim2.new(1, -65, 0, 0); Controls.BackgroundTransparency = 1

    local Min = Instance.new("TextButton", Controls)
    Min.Text = "-"; Min.Size = UDim2.new(0, 30, 1, 0); Min.BackgroundTransparency = 1; Min.TextColor3 = Color3.fromRGB(255, 255, 255); Min.TextSize = 18; Min.Font = "GothamBold"
    
    local Close = Instance.new("TextButton", Controls)
    Close.Text = "X"; Close.Position = UDim2.new(0, 30, 0, 0); Close.Size = UDim2.new(0, 30, 1, 0); Close.BackgroundTransparency = 1; Close.TextColor3 = Color3.fromRGB(255, 255, 255); Close.TextSize = 12; Close.Font = "GothamBold"

    local ReopenPill = Instance.new("TextButton", ScreenGui)
    ReopenPill.Size = UDim2.new(0, 100, 0, 32); ReopenPill.Position = UDim2.new(0.5, -50, 0.05, 0); ReopenPill.BackgroundColor3 = Color3.fromRGB(15, 15, 20); ReopenPill.TextColor3 = Color3.fromRGB(255, 255, 255); ReopenPill.Text = restoreText or "RESTORE"; ReopenPill.Visible = false; ReopenPill.Font = "GothamBold"; ReopenPill.TextSize = 10; ReopenPill.ClipsDescendants = true; Instance.new("UICorner", ReopenPill)
    Instance.new("UIStroke", ReopenPill).Color = Color3.fromRGB(255,255,255); ReopenPill.UIStroke.Transparency = 0.8
    CreateSnow(ReopenPill, 10)

    local ConfirmMenu = Instance.new("Frame", ScreenGui)
    ConfirmMenu.Size = UDim2.new(0, 240, 0, 120); ConfirmMenu.Position = UDim2.new(0.5, -120, -0.2, 0); ConfirmMenu.BackgroundColor3 = Color3.fromRGB(10, 10, 15); ConfirmMenu.BorderSizePixel = 0; ConfirmMenu.ClipsDescendants = true; Instance.new("UICorner", ConfirmMenu)
    Instance.new("UIStroke", ConfirmMenu).Color = Color3.fromRGB(255,255,255); ConfirmMenu.UIStroke.Transparency = 0.9
    CreateSnow(ConfirmMenu, 15)

    local ConfirmText = Instance.new("TextLabel", ConfirmMenu)
    ConfirmText.Text = "Are you sure you want to unload?"; ConfirmText.Size = UDim2.new(1, 0, 0.5, 0); ConfirmText.TextColor3 = Color3.fromRGB(255, 255, 255); ConfirmText.BackgroundTransparency = 1; ConfirmText.Font = "GothamBold"; ConfirmText.TextSize = 10; ConfirmText.TextWrapped = true

    local YesBtn = Instance.new("TextButton", ConfirmMenu)
    YesBtn.Text = "YES"; YesBtn.Size = UDim2.new(0, 80, 0, 30); YesBtn.Position = UDim2.new(0.2, 0, 0.6, 0); YesBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255); YesBtn.TextColor3 = Color3.fromRGB(0, 0, 0); YesBtn.Font = "GothamBold"; YesBtn.TextSize = 10; Instance.new("UICorner", YesBtn)

    local NoBtn = Instance.new("TextButton", ConfirmMenu)
    NoBtn.Text = "NO"; NoBtn.Size = UDim2.new(0, 80, 0, 30); NoBtn.Position = UDim2.new(0.55, 0, 0.6, 0); NoBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 25); NoBtn.TextColor3 = Color3.fromRGB(255, 255, 255); NoBtn.Font = "GothamBold"; NoBtn.TextSize = 10; Instance.new("UICorner", NoBtn)

    Close.MouseButton1Click:Connect(function() 
        ConfirmMenu:TweenPosition(UDim2.new(0.5, -120, 0.05, 0), "Out", "Back", 0.3, true)
    end)

    YesBtn.MouseButton1Click:Connect(function() 
        for _, toggle in pairs(Library.Toggles) do if toggle.State then toggle.Func(false) end end
        for _, slider in pairs(Library.Sliders) do slider.Func(slider.Default) end
        ScreenGui:Destroy() 
    end)

    NoBtn.MouseButton1Click:Connect(function() 
        ConfirmMenu:TweenPosition(UDim2.new(0.5, -120, -0.2, 0), "In", "Quad", 0.3, true)
    end)

    local Sidebar = Instance.new("ScrollingFrame", MainFrame)
    Sidebar.Size = UDim2.new(0, SidebarWidth, 1, -32); Sidebar.Position = UDim2.new(0, 0, 0, 32); Sidebar.BackgroundTransparency = 1; Sidebar.ScrollBarThickness = 0; Sidebar.CanvasSize = UDim2.new(0, 0, 0, 0)
    Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 4)
    Instance.new("UIPadding", Sidebar).PaddingLeft = UDim.new(0, 5); Sidebar.UIPadding.PaddingTop = UDim.new(0, 5)

    local Container = Instance.new("Frame", MainFrame)
    Container.Size = UDim2.new(1, -(SidebarWidth + 15), 1, -42); Container.Position = UDim2.new(0, SidebarWidth + 10, 0, 37); Container.BackgroundTransparency = 1; Container.ClipsDescendants = true

    Min.MouseButton1Click:Connect(function() MainFrame.Visible = false; ReopenPill.Visible = true end)
    ReopenPill.MouseButton1Click:Connect(function() MainFrame.Visible = true; ReopenPill.Visible = false end)

    makeDraggable(TitleBar, MainFrame)
    makeDraggable(ReopenPill, ReopenPill)

    local TabApi = {}
    function TabApi:CreateTab(name)
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(1, -5, 0, 28); TabBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 28); TabBtn.TextColor3 = Color3.fromRGB(150, 150, 150); TabBtn.Text = name; TabBtn.Font = "GothamBold"; TabBtn.TextSize = TextScale - 1; Instance.new("UICorner", TabBtn)

        local TabPage = Instance.new("ScrollingFrame", Container)
        TabPage.Size = UDim2.new(1, 0, 1, 0); TabPage.BackgroundTransparency = 1; TabPage.Visible = false; TabPage.ScrollBarThickness = 2
        TabPage.CanvasSize = UDim2.new(0, 0, 0, 0); TabPage.ScrollingDirection = Enum.ScrollingDirection.Y
        
        local Layout = Instance.new("UIListLayout", TabPage); Layout.Padding = UDim.new(0, 10); Layout.SortOrder = Enum.SortOrder.LayoutOrder
        Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() TabPage.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10) end)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.BackgroundColor3 = Color3.fromRGB(20,20,28); v.TextColor3 = Color3.fromRGB(150,150,150) end end
            TabPage.Visible = true; TabBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255); TabBtn.TextColor3 = Color3.fromRGB(0,0,0)
        end)
        
        if #Sidebar:GetChildren() == 2 then TabPage.Visible = true; TabBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255); TabBtn.TextColor3 = Color3.fromRGB(0,0,0) end

        local ElementApi = {}

        function ElementApi:AddSlider(text, min, max, default, callback)
            local sliderId = #Library.Sliders + 1
            Library.Sliders[sliderId] = { Func = callback, Default = default }
            
            local S = Instance.new("Frame", TabPage); S.Size = UDim2.new(1, -5, 0, 38); S.BackgroundTransparency = 1
            local L = Instance.new("TextLabel", S); L.Text = text .. ": " .. default; L.Size = UDim2.new(1,0,0,14); L.TextColor3 = Color3.fromRGB(255,255,255); L.BackgroundTransparency = 1; L.TextXAlignment = "Left"; L.Font = "GothamBold"; L.TextSize = TextScale - 1
            local Bar = Instance.new("Frame", S); Bar.Size = UDim2.new(0.9, 0, 0, 4); Bar.Position = UDim2.new(0, 5, 0, 24); Bar.BackgroundColor3 = Color3.fromRGB(35,35,45); Instance.new("UICorner", Bar)
            local Fill = Instance.new("Frame", Bar); Fill.Size = UDim2.new(0,0,1,0); Fill.BackgroundColor3 = Color3.fromRGB(255,255,255); Instance.new("UICorner", Fill); Fill.ZIndex = 2
            local Ball = Instance.new("Frame", Bar); Ball.Size = UDim2.new(0, 12, 0, 12); Ball.AnchorPoint = Vector2.new(0.5, 0.5); Ball.Position = UDim2.new(0,0,0.5,0); Ball.BackgroundColor3 = Color3.fromRGB(255,255,255); Ball.ZIndex = 4; Ball.BorderSizePixel = 0; Instance.new("UICorner", Ball).CornerRadius = UDim.new(1, 0)
            
            local isDragging = false
            local function update(input)
                local p = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                Fill.Size = UDim2.new(p, 0, 1, 0); Ball.Position = UDim2.new(p, 0, 0.5, 0)
                local val = math.floor(min + (max - min) * p); L.Text = text .. ": " .. val; callback(val)
            end
            
            Bar.InputBegan:Connect(function(input) 
                if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then 
                    isDragging = true; update(input) 
                end 
            end)
            
            UserInputService.InputChanged:Connect(function(input) 
                if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then 
                    update(input) 
                end 
            end)
            
            UserInputService.InputEnded:Connect(function(input) 
                if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then 
                    isDragging = false 
                end 
            end)
            
            local startP = math.clamp((default - min) / (max - min), 0, 1); Fill.Size = UDim2.new(startP, 0, 1, 0); Ball.Position = UDim2.new(startP, 0, 0.5, 0)
        end

        function ElementApi:AddToggle(text, callback)
            local toggleId = #Library.Toggles + 1
            Library.Toggles[toggleId] = { Func = callback, State = false }
            local T = Instance.new("Frame", TabPage); T.Size = UDim2.new(1, -5, 0, 28); T.BackgroundTransparency = 1
            local L = Instance.new("TextLabel", T); L.Text = text; L.Size = UDim2.new(1,0,1,0); L.TextColor3 = Color3.fromRGB(200,200,200); L.BackgroundTransparency = 1; L.TextXAlignment = "Left"; L.Font = "GothamBold"; L.TextSize = TextScale - 1
            local B = Instance.new("TextButton", T); B.Size = UDim2.new(0, 34, 0, 16); B.Position = UDim2.new(1,-34,0.5,-8); B.BackgroundColor3 = Color3.fromRGB(40,40,50); B.Text = ""; Instance.new("UICorner", B).CornerRadius = UDim.new(1,0)
            local Circle = Instance.new("Frame", B); Circle.Size = UDim2.new(0,12,0,12); Circle.Position = UDim2.new(0,2,0.5,-6); Circle.BackgroundColor3 = Color3.fromRGB(150,150,150); Instance.new("UICorner", Circle).CornerRadius = UDim.new(1,0)
            B.MouseButton1Click:Connect(function()
                Library.Toggles[toggleId].State = not Library.Toggles[toggleId].State
                local state = Library.Toggles[toggleId].State
                TweenService:Create(B, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(255,255,255) or Color3.fromRGB(40,40,50)}):Play()
                TweenService:Create(Circle, TweenInfo.new(0.2), {Position = state and UDim2.new(1,-14,0.5,-6) or UDim2.new(0,2,0.5,-6), BackgroundColor3 = state and Color3.fromRGB(0,0,0) or Color3.fromRGB(150,150,150)}):Play()
                callback(state)
            end)
        end

        function ElementApi:AddButton(text, callback)
            local B = Instance.new("TextButton", TabPage); B.Size = UDim2.new(1, -5, 0, 28); B.BackgroundColor3 = Color3.fromRGB(30, 30, 38); B.TextColor3 = Color3.fromRGB(255, 255, 255); B.Text = text; B.Font = "GothamBold"; B.TextSize = TextScale - 1; Instance.new("UICorner", B)
            B.MouseButton1Click:Connect(callback)
        end
        
        function ElementApi:AddLabel(text)
            local S = Instance.new("Frame", TabPage); S.Size = UDim2.new(1, -5, 0, 25); S.BackgroundTransparency = 1
            local L = Instance.new("TextLabel", S); L.Text = text:upper(); L.Size = UDim2.new(1, 0, 1, 0); L.TextColor3 = Color3.fromRGB(255, 255, 255); L.BackgroundTransparency = 1; L.Font = "GothamBold"; L.TextSize = TextScale - 2; L.TextXAlignment = "Left"
            local Line = Instance.new("Frame", S); Line.Size = UDim2.new(1, 0, 0, 1); Line.Position = UDim2.new(0, 0, 1, 0); Line.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Line.BackgroundTransparency = 0.9
        end

        return ElementApi
    end
    return TabApi
end

return Library
